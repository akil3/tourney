generator client {
  provider      = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Auth Models (NextAuth.js) ──

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          String    @default("player") // superadmin, player, captain
  accounts      Account[]
  sessions      Session[]
  captainOf     Team[]    @relation("TeamCaptain")
  adminOf       TournamentAdmin[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Tournament Models ──

model TournamentAdmin {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([userId, tournamentId])
}

model Tournament {
  id                 String   @id @default(cuid())
  name               String
  venue              String?
  startDate          DateTime?
  endDate            DateTime?
  format             String   @default("POOL_PLAY") // SINGLE_ELIMINATION, DOUBLE_ELIMINATION, ROUND_ROBIN, POOL_PLAY
  status             String   @default("DRAFT") // DRAFT, IN_PROGRESS, COMPLETED
  registrationOpen   DateTime?
  registrationClose  DateTime?
  settings           String   @default("{}") // JSON: setsToWin, pointsPerSetWin, poolCount, advancePerPool, pointsToWin, decidingSetPoints, pointCap, winBy
  teams              Team[]
  pools              Pool[]
  matches            Match[]
  brackets           Bracket[]
  admins             TournamentAdmin[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Team {
  id           String   @id @default(cuid())
  name         String
  captainId    String?
  captain      User?    @relation("TeamCaptain", fields: [captainId], references: [id])
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  poolId       String?
  pool         Pool?    @relation(fields: [poolId], references: [id])
  seed         Int?
  checkedIn    Boolean  @default(false)
  players      Player[]
  homeMatches  Match[]  @relation("HomeTeam")
  awayMatches  Match[]  @relation("AwayTeam")
  wonMatches   Match[]  @relation("MatchWinner")
  standings    Standing[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Player {
  id           String  @id @default(cuid())
  name         String
  jerseyNumber Int?
  isCaptain    Boolean @default(false)
  teamId       String
  team         Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
}

model Pool {
  id           String     @id @default(cuid())
  name         String
  sortOrder    Int        @default(0)
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teams        Team[]
  matches      Match[]
  standings    Standing[]
  createdAt    DateTime   @default(now())
}

model Bracket {
  id           String     @id @default(cuid())
  name         String     @default("Main Bracket")
  type         String     @default("SINGLE") // SINGLE, DOUBLE
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  matches      Match[]
  createdAt    DateTime   @default(now())
}

model Match {
  id              String     @id @default(cuid())
  tournamentId    String
  tournament      Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  poolId          String?
  pool            Pool?      @relation(fields: [poolId], references: [id])
  bracketId       String?
  bracket         Bracket?   @relation(fields: [bracketId], references: [id])
  bracketType     String?    // WINNERS, LOSERS, GRAND_FINALS, POOL
  round           Int        @default(1)
  matchNumber     Int        @default(0)
  homeTeamId      String?
  homeTeam        Team?      @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeamId      String?
  awayTeam        Team?      @relation("AwayTeam", fields: [awayTeamId], references: [id])
  court           String?
  scheduledTime   DateTime?
  status          String     @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, BYE
  sets            String     @default("[]") // JSON array of {home: number, away: number}
  homeScore       Int        @default(0) // sets won by home
  awayScore       Int        @default(0) // sets won by away
  winnerId        String?
  winner          Team?      @relation("MatchWinner", fields: [winnerId], references: [id])
  nextMatchId     String?
  nextMatch       Match?     @relation("WinnerAdvance", fields: [nextMatchId], references: [id])
  prevMatches     Match[]    @relation("WinnerAdvance")
  loserNextMatchId String?
  loserNextMatch  Match?     @relation("LoserAdvance", fields: [loserNextMatchId], references: [id])
  loserPrevMatches Match[]   @relation("LoserAdvance")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model Standing {
  id            String @id @default(cuid())
  poolId        String
  pool          Pool   @relation(fields: [poolId], references: [id], onDelete: Cascade)
  teamId        String
  team          Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  matchesPlayed Int    @default(0)
  wins          Int    @default(0)
  losses        Int    @default(0)
  setsWon       Int    @default(0)
  setsLost      Int    @default(0)
  pointsFor     Int    @default(0)
  pointsAgainst Int    @default(0)
  rank          Int?

  @@unique([poolId, teamId])
}
